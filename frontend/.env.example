# Frontend Environment Variables Template
# Copy this to .env (or configure in your deployment platform)

# Base URL for the main Node.js Backend API
# In production, this should point to your backend deployed URL (e.g. https://my-backend.onrender.com)
# If the frontend is served statically by the backend, this can be empty or relative like '/'
VITE_API_URL=http://localhost:9000

# Base URL for the AI Recommender Python Service
VITE_AI_RECOMMENDER_URL=http://localhost:5001

# Base URL for the AI Search Engine Python Service
VITE_AI_SEARCH_URL=http://localhost:5002
