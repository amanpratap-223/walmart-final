# Backend Environment Variables Template
# Copy this to .env (or configure in your deployment platform)

# Port for the Node.js server
PORT=9000

# MongoDB Connection String (Replace with your Atlas URI)
MONGO_URI=mongodb://localhost:27017/walmart-clone

# Secret key for JWT Authentication
JWT_SECRET=your_jwt_secret_key_here

# OpenAI API Key (Required for AI Chatbot)
OPENAI_API_KEY=your_openai_api_key_here

# Node Environment (Set to 'production' to serve frontend statically)
NODE_ENV=development

# Allowed Frontend Origin (for CORS, optional if serving statically)
FRONTEND_URL=http://localhost:5173
